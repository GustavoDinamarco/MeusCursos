# ============================================================
# Arquivo de exemplo — copie para .env e preencha os valores
# NÃO commitar o .env
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=courseuser
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=coursedb
POSTGRES_PORT=5432

# URL de conexão usada pelo SQLAlchemy (gerada a partir das vars acima)
# postgresql+asyncpg://<user>:<pass>@db:5432/<dbname>
# IMPORTANTE: caracteres especiais na senha devem ser URL-encoded (ex: @ → %40)
DATABASE_URL=postgresql+asyncpg://courseuser:TROQUE_ESTA_SENHA@db:5432/coursedb

# ---- MinIO ----
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=TROQUE_ESTA_SENHA_MINIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=course-videos
MINIO_ENDPOINT=http://minio:9000

# ---- Backend (FastAPI) ----
BACKEND_PORT=8000
SECRET_KEY=TROQUE_POR_UM_SEGREDO_FORTE_DE_32_CHARS_MINIMO

# ---- Frontend (Vite + React) ----
FRONTEND_PORT=3000

# ---- Notion (Passo 7) ----
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ---- Google API (Drive) ----
# Necessário apenas para importar pastas do Google Drive.
# Crie em https://console.cloud.google.com/ com Drive API v3 habilitada.
# O YouTube não precisa de API key (usa yt-dlp).
GOOGLE_API_KEY=

# ---- Local Import ----
# Pasta no host com videos para importar (montada read-only no container)
IMPORTS_HOST_PATH=./imports
